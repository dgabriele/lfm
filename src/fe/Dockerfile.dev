# Development image for the LFM Next.js front-end.
#
# Builds with dependencies baked in so `pnpm install` only runs on
# image build, not on every `docker compose up`.  Source is bind-mounted
# by docker-compose.yml so edits hot-reload via Turbopack.  The
# /app/node_modules path is kept as an image-owned volume so the
# container's linux-arm/amd64 binaries aren't shadowed by the host's.

FROM node:22-slim

# Corepack ships with Node 22 and manages pnpm/yarn versions declared
# in package.json.  Enabling it once here pins pnpm to whatever the
# project declares.
RUN corepack enable && corepack prepare pnpm@10.26.2 --activate

WORKDIR /app

# Install deps first so image layer is cached independent of source.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN --mount=type=cache,id=pnpm-store,target=/pnpm-store \
    pnpm config set store-dir /pnpm-store \
 && pnpm install --frozen-lockfile

# Source and .next are bind-mounted from the host at runtime.  Copy
# nothing further here.

EXPOSE 3000

CMD ["pnpm", "dev"]
